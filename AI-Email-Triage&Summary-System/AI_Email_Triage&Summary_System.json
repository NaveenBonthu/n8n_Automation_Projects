              "type": "string"
            },
            {
              "id": "cat-ai",
              "name": "category",
              "value": "={{\n  ($json.candidates?.[0]?.content?.parts?.[0]?.text || \"\")\n    .match(/Category:\\s*(.*)/)?.[1]\n    ?.trim()\n  || \"FYI\"\n}}",
              "type": "string"
