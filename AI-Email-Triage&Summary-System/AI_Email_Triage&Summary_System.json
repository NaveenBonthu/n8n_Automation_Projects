        "body": "={{ \nJSON.stringify({\n  contents: [\n    {\n      parts: [\n        {\n          text: `Classify the email into:\n- Urgent\n- Follow-up\n- FYI\n\nAlso give short summary max 8 words.\n\nReturn only:\nCategory: <value>\nSummary: <value>\n\nEmail:\nSubject: ${$json.subject || \"\"}\nBody: ${$json.body || \"\"}`\n        }\n      ]\n    }\n  ]\n})\n}}",
        "options": {}
