              "id": "sum-ai",
              "name": "summary",
              "value": "={{\n  ($json.candidates?.[0]?.content?.parts?.[0]?.text || \"\")\n    .match(/Summary:\\s*(.*)/)?.[1]\n    ?.trim()\n  || \"No summary\"\n}}",
              "type": "string"
            },
